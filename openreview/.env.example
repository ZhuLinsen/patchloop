# ============================================================
# OpenReview Agent — 环境变量配置
# ============================================================

# --- GitHub 配置 ---
# Personal Access Token (需要 repo 权限)
GITHUB_TOKEN=replace_me_read_token
# Webhook Secret (GitHub 仓库 Settings → Webhooks 中设置)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# 仓库 (格式: owner/repo)
GITHUB_REPO=owner/repo
# 同步失败时要 @ 的 GitHub 用户名 (可选；空=自动读取当前 token 对应账号)
GITHUB_NOTIFY_LOGIN=

# --- CLI 工具配置 ---
# 主 CLI: copilot | cursor | codex | opencode
PRIMARY_CLI=copilot
# 主 CLI 使用的模型 (空=默认模型)
PRIMARY_MODEL=
# 主 CLI 失败后回退到的模型 (仍使用同一个 PRIMARY_CLI)
PRIMARY_FALLBACK_MODEL=
# 模型参数 flag (如 --model, 空=不传)
PRIMARY_MODEL_FLAG=
# 自定义命令 (空=使用内置默认命令)
PRIMARY_CLI_COMMAND=

# 备用 CLI (空=不使用备用)
FALLBACK_CLI=
# 备用 CLI 的主模型
FALLBACK_MODEL=
# 备用 CLI 失败后回退到的模型
FALLBACK_FALLBACK_MODEL=
FALLBACK_MODEL_FLAG=
FALLBACK_CLI_COMMAND=

# CLI 超时秒数
CLI_TIMEOUT=180

# --- 服务配置 ---
SERVER_PORT=8000
LOG_LEVEL=INFO
# 触发模式: webhook | polling
EVENT_SOURCE=polling
# 启用 Webhook 接收 (需配合 GITHUB_WEBHOOK_SECRET)
ENABLE_WEBHOOK=false
# polling 模式轮询间隔（秒）
POLL_INTERVAL_SECONDS=60
# 每轮最多读取多少条 issue/pr
POLL_ITEMS_PER_PAGE=30
# 本地状态文件路径
STATE_FILE_PATH=.openreview-state.json
# dry-run 模式：只打印不实际发表评论
DRY_RUN=true
# 评论最大字符数
MAX_COMMENT_LENGTH=4000

# --- 本地仓库配置 ---
# 被分析的目标仓库本地路径；若目录不存在，启动时会自动 git clone GITHUB_REPO 到这里
LOCAL_REPO_PATH=/path/to/your/repo
# 默认分支名 (PR 分析完切回此分支)
LOCAL_REPO_DEFAULT_BRANCH=main
# 上下文构建参数
LOCAL_MAX_CONTEXT_FILES=6
LOCAL_MAX_FILE_CHARS=1800
LOCAL_MAX_TOTAL_CONTEXT_CHARS=12000
