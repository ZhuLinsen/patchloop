# ============================================================
# AutoCode Agent — 环境变量配置
# ============================================================

# --- GitHub 配置 ---
# Personal Access Token (需要 repo 权限)
GITHUB_TOKEN=replace_me_read_token
# Webhook Secret (GitHub 仓库 Settings → Webhooks 中设置)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# 仓库 (格式: owner/repo)
GITHUB_REPO=owner/repo
# 同步失败时要 @ 的 GitHub 用户名 (可选；空=自动读取当前 token 对应账号)
GITHUB_NOTIFY_LOGIN=

# --- CLI 工具配置 ---
# 主 CLI: copilot | cursor | codex | opencode
PRIMARY_CLI=copilot
# 主 CLI 使用的模型 (空=默认模型)
PRIMARY_MODEL=
# 主 CLI 失败后回退到的模型 (仍使用同一个 PRIMARY_CLI)
PRIMARY_FALLBACK_MODEL=
# 模型参数 flag (如 --model, 空=不传)
PRIMARY_MODEL_FLAG=
# 自定义命令 (空=使用内置默认命令)
PRIMARY_CLI_COMMAND=

# 备用 CLI (空=不使用备用)
FALLBACK_CLI=
# 备用 CLI 的主模型
FALLBACK_MODEL=
# 备用 CLI 失败后回退到的模型
FALLBACK_FALLBACK_MODEL=
FALLBACK_MODEL_FLAG=
FALLBACK_CLI_COMMAND=

# CLI 超时秒数
CLI_TIMEOUT=180

# --- 服务配置 ---
SERVER_PORT=8001
LOG_LEVEL=INFO
# 触发模式: webhook | polling
EVENT_SOURCE=polling
# 启用 Webhook 接收 (需配合 GITHUB_WEBHOOK_SECRET)；即使主模式是 polling，也可并行接收 webhook
ENABLE_WEBHOOK=false
# polling 模式轮询间隔（秒）
POLL_INTERVAL_SECONDS=300
# 每轮最多读取多少条 issue / issue_comment
POLL_ITEMS_PER_PAGE=5
# 本地状态文件路径
STATE_FILE_PATH=.autocode-service-state.json
# dry-run 模式：只打印不实际发表评论
DRY_RUN=true
# 评论最大字符数
MAX_COMMENT_LENGTH=4000

# --- 本地仓库配置 ---
# 被分析的目标仓库本地路径；若目录不存在，启动时会自动 git clone GITHUB_REPO 到这里
LOCAL_REPO_PATH=/path/to/your/repo
# 默认分支名 (PR 分析完切回此分支)
LOCAL_REPO_DEFAULT_BRANCH=main
# 上下文构建参数
LOCAL_MAX_CONTEXT_FILES=6
LOCAL_MAX_FILE_CHARS=1800
LOCAL_MAX_TOTAL_CONTEXT_CHARS=12000

# --- AutoCode 执行配置 ---
ENABLE_EXECUTION=true
EXECUTION_MODE=manual
EXECUTION_STATE_FILE_PATH=.autocode-state.json

# 写 Token：仅用于推送任务分支和创建 PR；建议与 GITHUB_TOKEN 分离
GITHUB_WRITE_TOKEN=

# issue opened 默认先 plan；feature 默认等人工 /implement
EXECUTION_AUTO_PLAN_ON_ISSUE_OPEN=true
EXECUTION_AUTO_IMPLEMENT_ON_ISSUE_OPEN=false

# 定期扫描 AutoCode PR 的 review 反馈并尝试追加修复
EXECUTION_POLL_REVIEW_FEEDBACK=true
EXECUTION_REVIEW_FEEDBACK_INTERVAL_SECONDS=300
EXECUTION_ENABLE_PR_QUEUE=true
# 需要进入 PR 队列持续跟踪的作者登录名，逗号分隔
EXECUTION_TRACK_PR_AUTHORS=your-bot-login
# 每轮最多真正执行多少个 PR 修复任务；其余继续排队
EXECUTION_PR_QUEUE_MAX_BATCH=1
EXECUTION_PLAN_COMMENT_HEADER=## AutoCode Plan
EXECUTION_BRANCH_PREFIX=autocode
EXECUTION_PUSH_REMOTE=origin

# PR 目标分支；留空时默认使用 LOCAL_REPO_DEFAULT_BRANCH
EXECUTION_PR_BASE_BRANCH=
# 默认创建普通 PR；如需 Draft，可显式改成 true
EXECUTION_FORCE_DRAFT_PR=false
# 兼容旧配置；默认关闭，不再要求把 PR 指向非 main 分支
EXECUTION_FORBID_MAIN_BASE_BRANCH=false
EXECUTION_ALLOW_FEATURE_ON_COMMENT=true
EXECUTION_ALLOWED_LABELS=
EXECUTION_REQUIRE_APPROVAL_FOR=small_feature,high_risk_feature
EXECUTION_BLOCKED_PATHS=.github/workflows/,infra/,deploy/,migrations/,secrets/,.env
EXECUTION_MAX_CHANGED_FILES=8
EXECUTION_MAX_ADDED_LINES=400
EXECUTION_MAX_DELETED_LINES=200
EXECUTION_TIMEOUT_SECONDS=1200
# issue 首次实现本地验证/补丁检查失败后，最多自动修复几轮
EXECUTION_ISSUE_REPAIR_MAX_ATTEMPTS=2
# PR review feedback 修复本地验证/补丁检查失败后，最多自动修复几轮
EXECUTION_REVIEW_FEEDBACK_REPAIR_MAX_ATTEMPTS=2
# false=尽量收集 format/lint/test 多个失败后再汇总给修复器；true=遇到首个失败即停止
EXECUTION_VALIDATION_FAIL_FAST=false
EXECUTION_WORKTREE_ROOT=/tmp/autocode-runs
EXECUTION_COMMIT_USER_NAME=AutoCode Bot
EXECUTION_COMMIT_USER_EMAIL=autocode-bot@example.com

# backlog / TODO 文件同步（可选）
EXECUTION_ENABLE_BACKLOG_SOURCE=false
EXECUTION_BACKLOG_FILE_PATHS=TODO.md,docs/BACKLOG.md
EXECUTION_BACKLOG_LABELS=autocode,backlog
EXECUTION_BACKLOG_TITLE_PREFIX=[Backlog]
EXECUTION_BACKLOG_MAX_ITEMS_PER_CYCLE=10

# 每行一条命令；为空则跳过对应校验
EXECUTION_FORMAT_COMMANDS=
EXECUTION_LINT_COMMANDS=
EXECUTION_TEST_COMMANDS=
